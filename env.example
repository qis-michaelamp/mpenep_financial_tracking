# Copy file ini jadi .env.local buat testing lokal, isi dengan value asli.
# JANGAN PERNAH commit file .env.local ke git!

# Dari BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Dari setWebhook secret_token, opsional tapi disarankan (lihat catatan deploy)
TELEGRAM_WEBHOOK_SECRET=

# Bebas isi string acak sendiri, dipakai buat proteksi endpoint cron
CRON_SECRET=

# Dari Supabase Project Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
